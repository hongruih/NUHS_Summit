# Copy this file to .env for local development.
# On Render/Railway, set these as environment variables in the dashboard.

# Port the app listens on (Render/Railway set this automatically)
PORT=5001

# Path to the SQLite database file.
# On Render with a persistent disk, set this to the mount path, e.g. /data/booth_data.db
DATABASE_PATH=booth_data.db

# Set to "true" only for local development
FLASK_DEBUG=false
